# Copy to .env and fill in values (never commit .env)

# PostgreSQL (required for local runs)
DATABASE_URL=postgresql://analyst:analyst_secure_pw@localhost:5432/revenue_integrity

# Slack incoming webhooks
SLACK_WEBHOOK_URL=
# Optional: route by severity
# SLACK_WEBHOOK_CRITICAL=
# SLACK_WEBHOOK_WARNING=
# SLACK_WEBHOOK_HEALTH=

# Alerting / pipeline
ALERT_COOLDOWN_HOURS=4

# Logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Optional: write Prometheus textfile after each run (node_exporter textfile collector)
# METRICS_TEXTFILE_PATH=/var/lib/node_exporter/revenue_integrity.prom

# Slack client tuning
# SLACK_TIMEOUT=10
# SLACK_RETRY_COUNT=3
# SLACK_RETRY_DELAY=2
